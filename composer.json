{
  "name": "milpa/command",
  "description": "The Command-as-atom core: the surface-agnostic Operation value object plus the CommandProvider and SurfaceProjector contracts. One operation, N surfaces.",
  "type": "library",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Rodrigo Vicente - TeamX Agency",
      "homepage": "https://teamx.agency"
    }
  ],
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpdoc-parser": "^2.3",
    "friendsofphp/php-cs-fixer": "^3.65",
    "milpa/core": "*"
  },
  "autoload": {
    "psr-4": {
      "Milpa\\Command\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Milpa\\Command\\Tests\\": "tests/",
      "Milpa\\Docs\\": "vendor/milpa/core/tools/gen-docs/"
    }
  }
}
